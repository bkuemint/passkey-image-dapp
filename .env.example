# Private key for the funded wallet (used by API routes for tx submission, server-only)
PRIVATE_KEY=0x...

# Deployed PasskeyImageConsumer contract address
NEXT_PUBLIC_CONSUMER_ADDRESS=0x...

# Ritual Chain RPC endpoints
NEXT_PUBLIC_RPC_URL=https://rpc.ritualfoundation.org
NEXT_PUBLIC_WS_URL=wss://rpc.ritualfoundation.org/ws

# HuggingFace Storage (for image output files)
HF_TOKEN=hf_...
HF_REPO=your-org/image-dapp-outputs

# Optional: Etherscan API key for contract verification
ETHERSCAN_API_KEY=
